# BitMEX Testnet API credentials
# Generate keys at: https://testnet.bitmex.com/app/apiKeys
# Permissions needed: Order (read + write) — do NOT enable withdraw permission
BITMEX_API_KEY=your_testnet_api_key_here
BITMEX_API_SECRET=your_testnet_api_secret_here

# Safety flag — order_manager.py will refuse to place any orders unless this is exactly "true"
# Never set this to true on a live/mainnet key
BITMEX_TESTNET=true

# Dashboard authentication (required for dashboard.py)
DASH_USER=admin
DASH_PASS=changeme
